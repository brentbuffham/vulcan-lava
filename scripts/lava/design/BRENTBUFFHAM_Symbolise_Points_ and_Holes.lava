sub triangle
{

	my ( $refX2, $refY2 ) = @_;
	&clearArrays;
	$xS[0] = (0 * $scale)  + $refX2;
	$xS[1] = (0.866	 * $scale)  + $refX2;
	$xS[2] = (-0.866 * $scale) + $refX2;
	$yS[0] = (1 * $scale)  + $refY2;
	$yS[1] = (-0.5 * $scale)  + $refY2;
	$yS[2] = (-0.5 * $scale) + $refY2;
	return ( \@xS, \@yS );
}

sub square
{

	my ( $refX3, $refY3 ) = @_;
	&clearArrays;
	$xS[0] = ( -0.707  * $scale) + $refX3;
	$xS[1] = ( -0.707 * $scale)  + $refX3;
	$xS[2] = (  0.707 * $scale)  + $refX3;
	$xS[3] = (  0.707  * $scale) + $refX3;
	$yS[0] = (  0.707 * $scale)  + $refY3;
	$yS[1] = (  -0.707* $scale)  + $refY3;
	$yS[2] = (  -0.707 * $scale) + $refY3;
	$yS[3] = (  0.707  * $scale) + $refY3;
	return ( \@xS, \@yS );
}

sub circle
{
	my ( $refX4, $refY4 ) = @_;
	&clearArrays;
	
	# no pen as is all drawn
	$xS[0] = (   0.0000 * $scale )  + $refX4;
