#!/usr/bin/perl
use Math::Trig qw(pi asin acos atan);

use Lava;
use Macro;
use vulcan;
use strict;
use warnings;
#################################################################################
#
#      Title           : BRENTBUFFHAM_Symbolise_Points_ and_Holes.lava
#      Version         : 3.0
#      Author          : Brent Buffham
#
#      Description     : Places a marker around a blast hole.
#                      : 6 Types Available - 
#							: Circle, Cross, Triangle, Square, Star, Comms
#
#      Primary Use(s)  : Creating hole markers on a reconcillation tie up
#                      : map, denoting first point in sequences.
#
#      Version 01 Date : 18 - MARCH - 2016
#      Version 01 Date : 30 - MARCH - 2016 - Added hole colour
#	   Version 02 Date : 02 - AUGUST - 2017 - Added star shape as #5
#      Version 03 Date : 29 - NOVEMBER - 2017 - Added Comms Wifi shape as #6
#
################################################################################
#arrays
my @xS;
my @yS;
my @zS;
my @draw;

my $colour;
my $objectName;
my $layerName;
my $layer;
my $scale  = 1;
my $marker = 3;
my $loop   = 1;

my $doColour = 0;
my $doMark = 1;

my $poly;
my %userSettings;



&loadDefaults;

while ( $loop == 1 )
{
	my $panel  = new Lava::Panel;
	#$panel->logical_button("Change hole colour.",\$doColour);
	#$panel->logical_button("Add Hole marker.",\$doMark);

	$panel->text("*******************************************************************************");
	$panel->text("                                     MARKER TYPES");
	$panel->text("   1 = Circle   |   2 = Cross |  3 = Triangle |  4 = Square  |  5 = Star  | 6 = COMMS");
	$panel->text("*******************************************************************************");	
	$panel->colour("Pick a Colour for the marker or Hole      ", \$colour );
	$panel->numeric("Select the type of Marker                 ", \$marker, 1, 0 );
	$panel->numeric("Default size is approx. 1 meter - Scale : ", \$scale, 6, 2 );

	if ( $panel->execute("User Inputs Panel") )
	{
		

		for ( my $object = new Lava::Selection( "Select object to Mark.", "multi,shadow" ) ; $object->has_more ; $object->next )
		{
		my $i          = 0;
		my $markerName = "";
			if ( $object->is_poly)
			{


				$layerName = $object->layer; #get the selected objects layer Name and store
				$objectName = $object->name; #get the selected objects Name and store
				Lava::Report("Objects Selected");
				my ( $x, $y, $z, $w, $con, $name ) = $object->coordinates->i;
				$xS[$i] = $x;
				$yS[$i] = $y;
				$zS[$i] = $z;
				my $tempY = sprintf( "%.3f", $xS[$i] );
				my $tempX = sprintf( "%.3f", $yS[$i] );
				my $tempZ = sprintf( "%.3f", $zS[$i] );

#				if($doColour == 1)
#				{
#					$object->colour($colour);
#					$object->replace();
#					
#				}

				
##				if($doMark == 1)
##				{
					$poly = new Lava::Obj();
					if ( $marker == 1 )
					{
						$markerName = "Circle";
						&circle( $xS[$i], $yS[$i], $scale );
						for(my $pID = 0; $pID < scalar(@xS); $pID++ )
						{
							my $cnt = $pID + 1 ;
							$poly->coordinates->i($pID, $xS[$pID], $yS[$pID], $z, "w-Value", 1,($pID+1));
							$poly->colour($colour);
							$poly->closed(1);
							$poly->name("CIRCLE");
						}
					}
					elsif ( $marker == 2 )
					{
						$markerName = "Cross";

						my ( $refX, $refY, $draw ) = &cross( $xS[$i], $yS[$i], $scale );

						@draw = @$draw;

						for(my $pID = 0; $pID < scalar(@xS); $pID++ )
						{
							my $cnt = $pID + 1 ;
							$poly->coordinates->i($pID, $xS[$pID], $yS[$pID], $z, "w-Value", $draw[$pID],($pID+1));
							$poly->colour($colour);
							$poly->name("CROSS");
						}
					}
					elsif ( $marker == 3 )
					{
						$markerName = "Triangle";
						&triangle( $xS[$i], $yS[$i], $scale );

						for(my $pID = 0; $pID < scalar(@xS); $pID++ )
						{
							my $cnt = $pID + 1 ;
							$poly->coordinates->i($pID, $xS[$pID], $yS[$pID], $z, "w-Value", 1,($pID+1));
							$poly->colour($colour);
							$poly->closed(1);
							$poly->name("TRIANGLE");
						}
					}
					elsif ( $marker == 4 )
					{
						$markerName = "Square";
						&square( $xS[$i], $yS[$i], $scale );

						for(my $pID = 0; $pID < scalar(@xS); $pID++ )
						{
							my $cnt = $pID + 1 ;
							$poly->coordinates->i($pID, $xS[$pID], $yS[$pID], $z, "w-Value", 1,($pID+1));
							$poly->colour($colour);
							$poly->closed(1);
							$poly->name("SQUARE");
						}

					}
					elsif ( $marker == 5 )
					{
						$markerName = "Star";
						&star( $xS[$i], $yS[$i], $scale );

						for(my $pID = 0; $pID < scalar(@xS); $pID++ )
						{
							my $cnt = $pID + 1 ;
							$poly->coordinates->i($pID, $xS[$pID], $yS[$pID], $z, "w-Value", 1,($pID+1));
							$poly->colour($colour);
							$poly->closed(1);
							$poly->name("STAR");
						}

					}
					elsif ( $marker == 6 )
					{
						$markerName = "Wifi";

						my ( $refX, $refY, $draw ) = &wifi( $xS[$i], $yS[$i], $scale );

						@draw = @$draw;

						for(my $pID = 0; $pID < scalar(@xS); $pID++ )
						{
							my $cnt = $pID + 1 ;
							$poly->coordinates->i($pID, $xS[$pID], $yS[$pID], $z, "w-Value", $draw[$pID],($pID+1));
							$poly->colour($colour);
							$poly->name("WIFI");
						}
					}
					else
					{
						Lava::Message("Not Supported Symbol.\nTerminating Script");
						die;
					}
#				} $doMark
				$layer = new Lava::Layer($object->layer);
				$layer->edited(1);

				$layer->add($poly);

				Lava::Report("Object[$objectName], x[$tempX], y[$tempY], z[$tempZ], Marker[$markerName]");
			}
			$i++;
		}


		&saveDefaults;
	}
	else
	{
		&saveDefaults;
		$loop = 0;
	}
}

sub refresh
{
	RunMenu("DESIGN_UNDO","abort",
      "FINISH") || die "Macro mismatch.\n";
   RunMenu("DESIGN_REDO","abort",
      "FINISH") || die "Macro mismatch.\n";
}

sub cross
{
	my ( $refX1, $refY1 ) = @_;
	my @pen;
	&clearArrays;
	$xS[0]  = (0.707 * $scale ) + $refX1;
	$xS[1]  = ( -0.707 * $scale ) + $refX1;
	$xS[2]  = ( -0.707 * $scale ) + $refX1;
	$xS[3]  = ( 0.707 * $scale ) + $refX1;
	$yS[0]  = ( 0.707 * $scale ) + $refY1;
	$yS[1]  = (-0.707 * $scale ) + $refY1;
	$yS[2]  = ( 0.707 * $scale ) + $refY1;
	$yS[3]  = (-0.707 * $scale ) + $refY1;
	$pen[0] = 1;
	$pen[1] = 1;
	$pen[2] = 0;
	$pen[3] = 1;
	return ( \@xS, \@yS, \@pen );
}

