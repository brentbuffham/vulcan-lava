sub star
{
	my ( $refX2, $refY2 ) = @_;
	&clearArrays;
	$xS[0] = (0     	* $scale)  	+ $refX2;
	$xS[1] = (0.225  	* $scale)  	+ $refX2;
	$xS[2] = (0.951  	* $scale) 	+ $refX2;
	$xS[3] = (0.363 	* $scale)  	+ $refX2;
	$xS[4] = (0.588  	* $scale)  	+ $refX2;
	$xS[5] = (0      	* $scale) 	+ $refX2;
	$xS[6] = (-0.588	* $scale)  	+ $refX2;
	$xS[7] = (-0.363 	* $scale)  	+ $refX2;
	$xS[8] = (-0.951 	* $scale) 	+ $refX2;
	$xS[9] = (-0.225	* $scale)  	+ $refX2;
	$yS[0] = (1     	* $scale)  	+ $refY2;
	$yS[1] = (0.309 	* $scale)  	+ $refY2;
	$yS[2] = (0.309 	* $scale) 	+ $refY2;
	$yS[3] = (-0.118	* $scale)  	+ $refY2;
	$yS[4] = (-0.809 	* $scale)  	+ $refY2;
	$yS[5] = (-0.382 	* $scale) 	+ $refY2;
	$yS[6] = (-0.809	* $scale)  	+ $refY2;
	$yS[7] = (-0.118 	* $scale)  	+ $refY2;
	$yS[8] = (0.309  	* $scale) 	+ $refY2;
	$yS[9] = (0.309 	* $scale)  	+ $refY2;
	return ( \@xS, \@yS );
}

#############################################
# CLEAR ARRAYS IN THIS SCRIPT
#############################################
sub clearArrays
{
	my @clean;
	@xS = @clean;
	@yS = @clean;
	@zS = @clean;
}
############################################
# Default Subroutines
############################################
sub loadDefaults
{

	# Load defaults into a hash
	dbmopen %userSettings, "symboliseblastholeDefaults", 0666;

	#Set the values to the default values
	$doMark = $userSettings{'doMark'} || 0;
	$doColour = $userSettings{'doColour'} || 1;
	$marker = $userSettings{'marker'} || 1;
	$colour = $userSettings{'colour'} || "";
	$scale  = $userSettings{'scale'}  || 1;
	dbmclose %userSettings;
}

sub saveDefaults
{

	# Save defaults into a hash
	dbmopen %userSettings, "symboliseblastholeDefaults", 0666;

	# Save the default values to the below
	$userSettings{'doMark'} = $doMark;
	$userSettings{'doColour'} = $doColour;
	$userSettings{'marker'} = $marker;
	$userSettings{'colour'} = $colour;
	$userSettings{'scale'} = $scale;
	dbmclose %userSettings;
}
